# Bot do Telegram
# Obtenha em: https://t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=SEU_TOKEN_TELEGRAM

# Firebase Admin (Service Account em JSON comprimido em uma linha)
# Console Firebase → Configurações → Contas de Serviço → Gerar nova chave privada
# Cole o conteúdo do JSON como string: FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"SEU_PROJECT_ID",...}

# GitHub (para acionar o workflow do Agente IA)
# Crie em: GitHub → Settings → Developer settings → Personal access tokens
# Permissões necessárias: repo (para acionar workflow_dispatch)
GITHUB_TOKEN=SEU_GITHUB_TOKEN_PERSONAL_ACCESS
GITHUB_REPO=RodrigoEscobar541/Controle-Financeiro

# ID do seu chat no Telegram (para o agente responder de volta)
# Envie /start ao bot e ele mostrará seu chat_id
TELEGRAM_CHAT_ID_AUTORIZADO=SEU_CHAT_ID

# Google Gemini API Key (para o Agente IA)
# Obtenha gratuitamente em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=SUA_GEMINI_API_KEY
